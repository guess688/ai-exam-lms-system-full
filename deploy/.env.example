# Docker deployment environment example.
# Copy this file to deploy/.env before running docker compose.
# Do not commit deploy/.env to GitHub.

# APP_PORT 只控制容器对外端口
# BASE_PATH 控制工程云访问前缀
# 如果工程云网关会剥离 /docker-10008 前缀，可以设置 BASE_PATH=
# 如果工程云网关不会剥离前缀，设置 BASE_PATH=/docker-10008
BASE_PATH=/docker-10008
APP_PORT=10008

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=db_exam
MYSQL_USERNAME=exam_user
MYSQL_PASSWORD=change_me_mysql_password

REDIS_PORT=6379
REDIS_PASSWORD=

SPRING_PROFILES_ACTIVE=prod

# Production must replace this with a long, random secret.
JWT_SECRET=change_me_to_a_long_random_secret

# AI_MOCK_ENABLED=true means the backend uses mock AI responses and does not call a real model API.
AI_PROVIDER=openai-compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_ENABLED=false
AI_MOCK_ENABLED=true

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=exam-files
MINIO_ENDPOINT=http://minio:9000

# External URL used by frontend/users to access uploaded files.
# For production, change this to the public MinIO API URL.
MINIO_EXTERNAL_ENDPOINT=http://服务器IP:9000

# Production checklist:
# 1. Change JWT_SECRET.
# 2. Change MySQL root/user passwords.
# 3. Change MinIO root password.
# 4. Keep AI_API_KEY empty when mock mode is enabled; never commit a real AI API key.
