{
  "type": "object",
  "required": ["needTeacherReview", "questions"],
  "properties": {
    "summary": { "type": "string" },
    "needTeacherReview": { "const": true },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "quType", "difficulty", "content", "options", "answer", "analysis"],
        "properties": {
          "type": { "enum": ["SINGLE", "MULTIPLE", "INDEFINITE", "JUDGE"] },
          "quType": { "enum": [1, 2, 3, 4] },
          "difficulty": { "enum": ["EASY", "MEDIUM", "HARD"] },
          "content": { "type": "string" },
          "options": { "type": "array" },
          "answer": { "type": "array" },
          "analysis": { "type": "string" }
        }
      }
    }
  }
}
